# Canonical ABI export list for libJavaSupport.so
# Generated from: nm -g vmStructs.o | grep '[BDRGS]' plus function entry points.
# Consumed by NativeLinkTask (version script on Linux, exported-symbols-list on macOS).
# Lines starting with '#' are comments; blank lines are ignored.
#
# Excluded private implementation statics:
#   _ZN9VMStructs7_libjvmE      (internal CodeCache ptr)
#   _ZN9VMStructs10_lock_funcE  (private mutex helper)
#   _ZN9VMStructs12_unlock_funcE
#   _ZN9VMStructs11_flag_countE (private VMFlag count)
#   _ZN9VMStructs11_flags_addrE (private VMFlag array addr)
#   _ZN9VMStructs10_code_heapE  (private 3-slot code heap array)

# Entry points
_ZN9VMStructs4initEP9CodeCache
_ZN9VMStructs5readyEv

# JVMAccess JNI entry points (support library provides these; loaded by JVMAccess before the profiler)
Java_com_datadoghq_profiler_JVMAccess_findStringJVMFlag0
Java_com_datadoghq_profiler_JVMAccess_setStringJVMFlag0
Java_com_datadoghq_profiler_JVMAccess_findBooleanJVMFlag0
Java_com_datadoghq_profiler_JVMAccess_setBooleanJVMFlag0
Java_com_datadoghq_profiler_JVMAccess_findIntJVMFlag0
Java_com_datadoghq_profiler_JVMAccess_findFloatJVMFlag0
Java_com_datadoghq_profiler_JVMAccess_healthCheck0

# Crash-protection probe (C linkage + helpers)
g_crash_protection_probe
_Z25crashProtectionProbeResetv
_Z29crashProtectionProbeIsDefaultv

# isJavaThread probe + reset
_ZN8VMThread22g_is_java_thread_probeE
_ZN8VMThread22resetIsJavaThreadProbeEv

